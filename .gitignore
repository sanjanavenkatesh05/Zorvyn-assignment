# =============================================================================
# Zorvyn Finance Backend — Git Ignore Rules
# =============================================================================

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ── Environment ──────────────────────────────────────────────────────────────
.env
.venv/
venv/
env/

# ── Testing ──────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Docker ───────────────────────────────────────────────────────────────────
# Don't ignore docker-compose.yml or Dockerfile — they're needed for builds

# ── mypy ─────────────────────────────────────────────────────────────────────
.mypy_cache/
